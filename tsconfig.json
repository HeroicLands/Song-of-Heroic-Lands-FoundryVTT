{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "skipLibCheck": true,
        "useDefineForClassFields": false,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "outDir": "./build/generated",
        "strict": true,
        "noEmitOnError": true,
        "types": ["fvtt-types/lenient", "vitest/globals"],
        "paths": {
            "@types/*": ["./types/*"],
            "@src/*": ["./src/*"],
            "@templates/*": ["./templates/*"],
            "@assets/*": ["./assets/*"],
            "@lang/*": ["./lang/*"],
            "@tests/*": ["./tests/*"]
        }
    },
    "include": ["src/**/*.ts", "tests/**/*.ts", "types/index.d.ts"],
    "exclude": ["build/docs", "build/generated", "build/stage", "build/tmp"]
}
