<section class="tab trauma{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="trauma">
    {{!-- Injuries (trauma items) --}}
    <fieldset>
        <legend>
            Injuries
        </legend>
        <ol class="list__items">
            <li class="list__header flexrow">
                <h3 class="list__name">Injury</h3>
                <div class="list__detail" data-tooltip="Injury Severity">Sev</div>
                <div class="list__detail" data-tooltip="Healing Rate (NT = not treated)">HR</div>
                <div class="list__detail">Aspect</div>
                <div class="list__detail">Area</div>
                <div class="list__detail" data-tooltip="Bleeding">Bld</div>
                <div class="list__detail list__notes">Notes</div>
                <div class="list__controls">
                    <a class="item-create" data-action="createItem" data-type="trauma" data-tooltip="Create a trauma item manually">
                        <i class="fa-solid fa-file-plus"></i>
                    </a>
                </div>
            </li>
            {{#each traumas as |injury|}}
            <li class="item flexrow" data-search-name="{{injury.name}}" data-item-id="{{injury.id}}" data-item-name="{{injury.name}}">
                <div class="list__name default-action flexrow">
                    <div class="list__image" style="background-image: url('{{injury.img}}')"></div>
                    <h4 data-tooltip="{{injury.name}}">{{injury.name}}</h4>
                </div>
                <div class="list__detail" data-tooltip="Severity">
                    {{#if injury.healed}}
                    <i class="fa-solid fa-heart-circle-plus" data-tooltip="Healed"></i>
                    {{else}}
                    {{injury.severity}}
                    {{/if}}
                </div>
                <div class="list__detail" data-tooltip="Healing Rate">
                    {{#if injury.healingRateDisabled}}
                    <i class="fa-solid fa-xmark fa-lg"></i>
                    {{else}}
                    {{#unless injury.isTreated}}NT{{/unless}}{{injury.healingRate}}
                    {{/if}}
                </div>
                <div class="list__detail">{{injury.aspect}}</div>
                <div class="list__detail">{{injury.area}}</div>
                <div class="list__detail">
                    {{#if injury.isBleeding}}
                    <span class="danger">Yes</span>
                    {{else}}
                    No
                    {{/if}}
                </div>
                <div class="list__detail list__notes" data-tooltip="{{injury.notes}}">{{injury.notes}}</div>
                <div class="list__controls">
                    <a class="list__control item-contextmenu" title="Menu"><i class="fa-solid fa-ellipsis-vertical fa-fw"></i></a>
                </div>
            </li>
            {{/each}}
        </ol>
    </fieldset>

    {{!-- Afflictions (no search filter — #312) --}}
    <div class="search-items">
        <div class="search-controls">
            <a class="search-control item-create" data-action="createItem" data-type="affliction" data-tooltip="Create Affliction">
                <i class="fa-solid fa-file-plus"></i>
            </a>
        </div>
    </div>

    <div class="afflictions-list">
        {{#each afflictionGroups as |group|}}
        <fieldset>
            <legend>{{group.label}} Afflictions</legend>
            <ol class="list__items">
                <li class="list__header flexrow">
                    <h3 class="list__name">Affliction</h3>
                    <div class="list__detail" data-tooltip="Level">Level</div>
                    <div class="list__detail" data-tooltip="Healing Rate">HR</div>
                    <div class="list__detail">Source</div>
                    <div class="list__detail list__notes">Notes</div>
                    <div class="list__controls"></div>
                </li>
                {{#each group.afflictions as |aff|}}
                <li class="item flexrow" data-search-name="{{aff.name}}" data-item-id="{{aff.id}}" data-item-name="{{aff.name}}">
                    <div class="list__name default-action flexrow">
                        <div class="list__image" style="background-image: url('{{aff.img}}')"></div>
                        <h4 data-tooltip="{{aff.name}}">{{aff.name}}</h4>
                    </div>
                    <div class="list__detail" data-tooltip="Level">{{aff.level}}</div>
                    <div class="list__detail" data-tooltip="Healing Rate">
                        {{#if aff.healingRateDisabled}}
                        <i class="fa-solid fa-xmark fa-lg"></i>
                        {{else}}
                        {{aff.healingRate}}
                        {{/if}}
                    </div>
                    <div class="list__detail">{{aff.source}}</div>
                    <div class="list__detail list__notes" data-tooltip="{{aff.notes}}">{{aff.notes}}</div>
                    <div class="list__controls">
                        <a class="list__control item-contextmenu" title="Menu"><i class="fa-solid fa-ellipsis-vertical fa-fw"></i></a>
                    </div>
                </li>
                {{/each}}
            </ol>
        </fieldset>
        {{/each}}
    </div>
</section>
