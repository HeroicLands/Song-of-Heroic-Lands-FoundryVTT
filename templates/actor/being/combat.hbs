<section class="tab combat{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="combat">
    {{!-- Melee Strike Modes: combat techniques + held melee weapons --}}
    {{#if meleeStrikeModes.length}}
        <header class="list__header flexrow">
            <h3 class="list__name">Melee Strike Modes</h3>
            <div class="list__detail" data-tooltip="Heft">HFT</div>
            <div class="list__detail" data-tooltip="Reach">RCH</div>
            <div class="list__detail" data-tooltip="{{#if @root.useZoneDie}}Zone Dice{{else}}Spread{{/if}}">{{@root.spreadLabel}}</div>
            <div class="list__detail" data-tooltip="Impact">Impact</div>
            <div class="list__detail" data-tooltip="Attack ML">Atk</div>
            <div class="list__detail" data-tooltip="Block ML">Blk</div>
            <div class="list__detail" data-tooltip="Counterstrike ML">CX</div>
            <div class="list__controls">
            </div>
        </header>

        {{#each meleeStrikeModes as |entry|}}
        <div class="list">
            <ol class="list__items">
                <li class="list__header flexrow">
                    <h3 class="list__name name">{{entry.weapon.name}}</h3>
                </li>
                {{#each entry.strikeModes as |sm|}}
                <li class="item flexrow" data-sm-id="{{sm.id}}" data-item-id="{{entry.weapon.id}}">
                    <div class="list__name default-action flexrow">
                        <h4 data-tooltip="{{sm.name}}">{{sm.name}}</h4>
                    </div>
                    <div class="list__detail">{{sm.heft.effective}}</div>
                    <div class="list__detail">{{sm.reach.effective}}</div>
                    <div class="list__detail">{{#if @root.useZoneDie}}d{{/if}}{{sm.spread.effective}}</div>
                    {{#unless sm.impact.disabled}}
                    <div class="list__detail rollable" data-action="rollStrikeModeImpact">
                        {{sm.impact.label}}
                    </div>
                    {{else}}
                    <div class="list__detail">
                        <i class="fa-solid fa-xmark fa-lg"></i>
                    </div>
                    {{/unless}}
                    {{#unless sm.attack.disabled}}
                    <div class="list__detail rollable" data-action="rollStrikeModeTest" data-test-kind="attack">{{sm.attack.effective}}</div>
                    {{else}}
                    <div class="list__detail"><i class="fa-solid fa-xmark fa-lg"></i></div>
                    {{/unless}}
                    {{#unless sm.defense.block.disabled}}
                    <div class="list__detail rollable" data-action="rollStrikeModeTest" data-test-kind="block">{{sm.defense.block.effective}}</div>
                    {{else}}
                    <div class="list__detail"><i class="fa-solid fa-xmark fa-lg"></i></div>
                    {{/unless}}
                    {{#unless sm.defense.counterstrike.disabled}}
                    <div class="list__detail rollable" data-action="rollStrikeModeTest" data-test-kind="counterstrike">{{sm.defense.counterstrike.effective}}</div>
                    {{else}}
                    <div class="list__detail"><i class="fa-solid fa-xmark fa-lg"></i></div>
                    {{/unless}}
                    <div class="list__controls">
                    </div>
                </li>
                {{/each}}
            </ol>
        </div>
        {{/each}}
    {{/if}}

    {{!-- Missile Strike Modes: combat techniques + held missile weapons --}}
    {{#if missileStrikeModes.length}}
        {{#each missileStrikeModes as |entry|}}
        <div class="list">
            <header class="list__header flexrow">
                <h3 class="list__name">Missile Strike Modes</h3>
                <div class="list__detail" data-tooltip="Pull Strength">Pull</div>
                <div class="list__detail" data-tooltip="Draw Time">Draw</div>
                <div class="list__detail" data-tooltip="Base Range">BR</div>
                <div class="list__detail" data-tooltip="Max Volley Multiplier">MaxVM</div>
                <div class="list__detail" data-tooltip="Impact">Impact</div>
                <div class="list__detail" data-tooltip="Attack ML">Atk</div>
                <div class="list__controls">
                </div>
            </header>
            <ol class="list__items">
                <li class="list__header flexrow">
                    <h3 class="list__name name">{{entry.weapon.name}}</h3>
                </li>
                {{#each entry.strikeModes as |sm|}}
                <li class="item flexrow" data-sm-id="{{sm.id}}" data-item-id="{{entry.weapon.id}}">
                    <div class="list__name default-action flexrow">
                        <h4 data-tooltip="{{sm.name}}">{{sm.name}}</h4>
                    </div>
                    <div class="list__detail">{{sm.draw.effective}}</div>
                    <div class="list__detail">{{sm.draw.effective}}</div>
                    <div class="list__detail">{{sm.baseRange.effective}}</div>
                    <div class="list__detail">{{sm.maxVolleyMult}}</div>
                    {{#unless sm.impact.disabled}}
                    <div class="list__detail rollable" data-action="rollStrikeModeImpact" data-tooltip="Roll impact">
                        {{sm.impact.label}}
                    </div>
                    {{else}}
                    <div class="list__detail">
                        <i class="fa-solid fa-xmark fa-lg"></i>
                    </div>
                    {{/unless}}
                    {{#unless sm.attack.disabled}}
                    <div class="list__detail rollable" data-action="rollStrikeModeTest" data-test-kind="attack" data-tooltip="Roll attack (shift-click to skip dialog)">{{sm.attack.effective}}</div>
                    {{else}}
                    <div class="list__detail"><i class="fa-solid fa-xmark fa-lg"></i></div>
                    {{/unless}}
                    <div class="list__controls">
                    </div>
                </li>
                {{/each}}
            </ol>
        </div>
        {{/each}}
    {{/if}}

    {{!-- Held Items — one dropdown per hold-capable limb --}}
    {{#if heldItemLimbs.length}}
    <fieldset>
        <legend>Held Items</legend>
        <ol class="list__items held-items">
            {{#each heldItemLimbs as |limb|}}
            <li class="item flexrow" data-part-index="{{limb.index}}">
                <div class="list__name"><h4>{{limb.label}}</h4></div>
                <div class="list__detail">
                    <select class="held-item-select" data-part-index="{{limb.index}}">
                        <option value="">—</option>
                        {{#each @root.holdableItems as |it|}}
                        <option value="{{it.id}}" {{#if (eq it.id limb.heldItemId)}}selected{{/if}}>{{it.name}}</option>
                        {{/each}}
                    </select>
                </div>
            </li>
            {{/each}}
        </ol>
    </fieldset>
    {{/if}}

    {{#if isGM}}
    {{!-- Default combat group: auto-assigns this actor's combatants on combat start --}}
        <div class="form-group">
            {{formGroup fields.defaultCombatGroup
                classes="text-field"
                placeholder="Opponents"
                localize=true
                stacked=false
                value=system.defaultCombatGroup}}
        </div>
    {{/if}}

    {{!-- Body Locations: read-only Part → Location tree with effective armor
         totals (natural protection + worn armor) per location. --}}
    {{#if structure}}
        <div class="search-items">
            <input class="search-criteria" type="search" name="search-bodylocations" value=""
                aria-label="Search Body Locations" placeholder="Search Body Locations" autocomplete="off" />
        </div>
        <div class="bodylocations-list">
            <header class="list__header flexrow">
                <h3 class="list__name">Location</h3>
                <div class="list__detail">Layers</div>
                <div class="list__detail" data-tooltip="Blunt">B</div>
                <div class="list__detail" data-tooltip="Edged">E</div>
                <div class="list__detail" data-tooltip="Piercing">P</div>
                <div class="list__detail" data-tooltip="Fire">F</div>
                <div class="list__detail" data-tooltip="Shock">Shock</div>
                <div class="list__detail" data-tooltip="Impairment">Impair</div>
            </header>
            {{#each bodyParts as |part|}}
            <div class="list bodypart">
                <header class="list__header bodypart__header flexrow">
                    <h3 class="list__name">{{part.label}}</h3>
                </header>
                <ol class="list__items">
                    {{#each part.locations as |loc|}}
                    <li class="item bodylocation flexrow" data-search-name="{{loc.name}}">
                        <div class="list__name"><h4>{{loc.name}}</h4></div>
                        <div class="list__detail bodylocation__layers">{{loc.layers}}</div>
                        <div class="list__detail">{{loc.blunt}}</div>
                        <div class="list__detail">{{loc.edged}}</div>
                        <div class="list__detail">{{loc.piercing}}</div>
                        <div class="list__detail">{{loc.fire}}</div>
                        <div class="list__detail">{{loc.shock}}</div>
                        <div class="list__detail">{{loc.impair}}</div>
                    </li>
                    {{/each}}
                </ol>
            </div>
            {{/each}}
        </div>
    {{/if}}
</section>
