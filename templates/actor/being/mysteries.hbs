<section class="tab mysteries{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="mysteries">
    {{!-- Mysteries — one section per subtype, header always shown (#310) --}}
    <div class="search-items">
        <input class="search-criteria" type="search" name="search-mysteries" value=""
            aria-label="Search Mysteries" placeholder="Search Mysteries" autocomplete="off" />
    </div>
    <div class="mysteries-list">
        {{#each mysterySections as |section|}}
        <fieldset>
            <legend>{{section.label}} Mysteries</legend>
            <ol class="list__items">
                <li class="list__header flexrow">
                    <h3 class="list__name">Mystery</h3>
                    <div class="list__detail">Skill</div>
                    <div class="list__detail">Level</div>
                    <div class="list__detail">Charges</div>
                    <div class="list__detail">Notes</div>
                </li>
                {{#each section.items as |mystery|}}
                <li class="item flexrow" data-search-name="{{mystery.name}}" data-item-id="{{mystery.id}}" data-item-name="{{mystery.name}}">
                    <div class="list__name default-action flexrow">
                        <div class="list__image" style="background-image: url('{{mystery.img}}')"></div>
                        <h4 data-tooltip="{{mystery.name}}">{{mystery.name}}</h4>
                    </div>
                    <div class="list__detail">{{#if mystery.logic.assocSkill}}{{mystery.logic.assocSkill.name}}{{/if}}</div>
                    <div class="list__detail">
                        {{!-- Level: "×" when disabled (levelBase null), else signed value --}}
                        {{#if mystery.logic.level.disabled}}
                        <i class="sohl-xmark"></i>
                        {{else}}
                        {{numberFormat mystery.logic.level.effective sign=true}}
                        {{/if}}
                    </div>
                    <div class="list__detail">
                        {{!-- Charges display rules (#310), first match wins:
                              max disabled → "×"; value disabled → "∞";
                              max 0 → "<value>/∞"; else "<value>/<max>" --}}
                        {{#if mystery.logic.charges.max.disabled}}
                        <i class="sohl-xmark"></i>
                        {{else}}
                        {{#if mystery.logic.charges.value.disabled}}
                        &infin;
                        {{else}}
                        {{mystery.logic.charges.value.effective}}/{{#if (eq mystery.logic.charges.max.effective 0)}}&infin;{{else}}{{numberFormat mystery.logic.charges.max.effective}}{{/if}}
                        {{/if}}
                        {{/if}}
                    </div>
                    <div class="list__detail">{{mystery.system.notes}}</div>
                    <div class="list__controls">
                        <a class="list__control item-contextmenu" title="Menu"><i class="sohl-ellipsis-vertical"></i></a>
                    </div>
                </li>
                {{/each}}
            </ol>
        </fieldset>
        {{/each}}
    </div>

    {{!-- Mystical Abilities — one section per subtype, header always shown (#311) --}}
    <div class="search-items">
        <input class="search-criteria" type="search" name="search-mysticalabilities" value=""
            aria-label="Search Mystical Abilities" placeholder="Search Mystical Abilities" autocomplete="off" />
    </div>
    <div class="mysticalabilities-list">
        {{#each abilitySections as |section|}}
        <fieldset>
            <legend>{{section.label}} Mystical Abilities</legend>
            <ol class="list__items">
                <li class="list__header flexrow">
                    <h3 class="list__name">Ability</h3>
                    <div class="list__detail">Skill</div>
                    <div class="list__detail" data-tooltip="Level">Lvl</div>
                    <div class="list__detail" data-tooltip="Mastery Level">ML</div>
                    <div class="list__detail">Charges</div>
                    <div class="list__detail" data-tooltip="Improve via SDR">Imp</div>
                    <div class="list__detail">Notes</div>
                </li>
                {{#each section.items as |ability|}}
                <li class="item flexrow" data-search-name="{{ability.name}}" data-item-id="{{ability.id}}" data-item-name="{{ability.name}}">
                    <div class="list__name default-action flexrow">
                        <div class="list__image" style="background-image: url('{{ability.img}}')"></div>
                        <h4 data-tooltip="{{ability.name}}">{{ability.name}}</h4>
                    </div>
                    <div class="list__detail">{{#if ability.logic.assocSkill}}{{ability.logic.assocSkill.name}}{{/if}}</div>
                    <div class="list__detail">
                        {{!-- Level: "×" when disabled (levelBase null), else value --}}
                        {{#if ability.logic.level.disabled}}
                        <i class="sohl-xmark"></i>
                        {{else}}
                        {{ability.logic.level.effective}}
                        {{/if}}
                    </div>
                    <div class="list__detail">
                        {{#if ability.logic.masteryLevel.disabled}}
                        <i class="sohl-xmark"></i>
                        {{else}}
                        {{ability.logic.masteryLevel.effective}}
                        {{/if}}
                    </div>
                    <div class="list__detail">
                        {{!-- Charges display rules (#311), first match wins:
                              max disabled → "×"; value disabled → "∞";
                              max 0 → "<value>/∞"; else "<value>/<max>" --}}
                        {{#if ability.logic.charges.max.disabled}}
                        <i class="sohl-xmark"></i>
                        {{else}}
                        {{#if ability.logic.charges.value.disabled}}
                        &infin;
                        {{else}}
                        {{ability.logic.charges.value.effective}}/{{#if (eq ability.logic.charges.max.effective 0)}}&infin;{{else}}{{numberFormat ability.logic.charges.max.effective}}{{/if}}
                        {{/if}}
                        {{/if}}
                    </div>
                    <div class="list__detail">
                        <a class="list__control toggle-improve-flag" data-action="toggleImproveFlag" title="Improve">
                            <i class="{{#if ability.system.improveFlag}}sohl-round-star-filled{{else}}sohl-round-star-unfilled{{/if}}"></i>
                        </a>
                    </div>
                    <div class="list__detail">{{ability.system.notes}}</div>
                    <div class="list__controls">
                        <a class="list__control item-contextmenu" title="Menu"><i class="sohl-ellipsis-vertical"></i></a>
                    </div>
                </li>
                {{/each}}
            </ol>
        </fieldset>
        {{/each}}
    </div>
</section>
