<section class="tab profile{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="profile">
    {{!-- Attributes --}}
    <fieldset>
        <legend>
            Attributes
            <a class="item-create" data-action="createItem" data-tooltip="Add Attribute" data-type="attribute">
                <i class="sohl-file-create"></i>
            </a>
        </legend>
        <div class="grid grid-4col attribute-scores">
            {{#each attributes as |attr|}}
            <div class="attribute-score item" data-item-id="{{attr.id}}" data-uuid="{{attr.uuid}}" data-item-name="{{attr.name}}">
                <div class="attribute-score__header flexrow">
                    <h4 class="attribute-score__name">{{attr.name}}</h4>
                    <a class="item-contextmenu" title="Menu"><i class="sohl-ellipsis-vertical"></i></a>
                </div>
                <div class="attribute-score__value">{{attr.score}}</div>
                <div class="attribute-score__descriptor">{{attr.descriptor}}</div>
                <div class="attribute-score__tl">TL: {{attr.tl}}</div>
            </div>
            {{/each}}
        </div>
    </fieldset>

    {{!-- Traits --}}
    {{#each traitGroups as |traits groupName|}}
    <fieldset>
        <legend>{{@key}}</legend>
        <ol class="list__items traits">
            {{#each traits as |trait|}}
            <li class="item flexrow" data-search-name="{{trait.name}}" data-item-id="{{trait.id}}" data-item-name="{{trait.name}}">
                <div class="list__name flexrow">
                    <h4>{{trait.name}}</h4>
                </div>
                <div class="list__detail">
                    {{#if trait.system.isNumeric}}{{trait.system.masteryLevelBase}}{{else}}{{trait.system.textValue}}{{/if}}
                </div>
                <div class="list__controls">
                    <a class="list__control item-contextmenu" title="Menu"><i class="sohl-ellipsis-vertical"></i></a>
                </div>
            </li>
            {{/each}}
        </ol>
    </fieldset>
    {{/each}}

    {{!-- Affiliations --}}
    {{#if affiliations.length}}
    <fieldset>
        <legend>Affiliations</legend>
        <ol class="list__items">
            {{#each affiliations as |aff|}}
            <li class="item flexrow" data-item-id="{{aff.id}}">
                <div class="list__name"><h4>{{aff.name}}</h4></div>
                <div class="list__detail">{{aff.system.society}}</div>
                <div class="list__detail">{{aff.system.title}}</div>
                <div class="list__controls">
                    <a class="list__control item-contextmenu" title="Menu"><i class="sohl-ellipsis-vertical"></i></a>
                </div>
            </li>
            {{/each}}
        </ol>
    </fieldset>
    {{/if}}

    {{!-- Movement --}}
    {{#if movement.length}}
    <fieldset>
        <legend>{{localize "SOHL.Being.movement.legend"}}</legend>
        <ol class="list__items movement">
            {{#each movement as |row|}}
            <li class="item flexrow" data-medium="{{row.medium}}">
                <div class="list__name"><h4>{{localize row.label}}</h4></div>
                <div class="list__detail">{{row.value}} {{localize "SOHL.Being.movement.unit"}}</div>
            </li>
            {{/each}}
        </ol>
    </fieldset>
    {{/if}}

    {{!-- Biography --}}
    <fieldset>
        <legend>Biography</legend>
        {{editor biographyHTML target="system.biography" button=false editable=editable engine="prosemirror" collaborate=false}}
    </fieldset>
</section>
