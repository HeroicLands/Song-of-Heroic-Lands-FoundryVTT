<header class="sheet-header flexrow">
    <img class="actor-img" src="{{actorImg}}" data-edit="img" alt="{{actorName}}" />
    <div class="header-details">
        <h1 class="actor-name">
            <input name="name" type="text" value="{{actorName}}" placeholder="{{localize 'Name'}}" />
        </h1>
        <div class="status-effects">
            {{#each statusEffects as |active id|}}
            <a class="toggle-status-effect {{#if active}}active{{/if}}" data-status-id="{{@key}}" data-tooltip="{{@key}}">
                <i class="fas fa-circle"></i>
            </a>
            {{/each}}
        </div>
    </div>
</header>
