<section class="tab properties{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="properties">
    <div class="grid grid-2col">
        {{!-- A measured trait (#532) owns a numeric score + cap; descriptive
              subtypes own a textValue (or a choice-driven value). --}}
        {{#if (eq system.subType "measured")}}
        {{formGroup fields.score.fields.value value=system.score.value classes="stacked" rootId="trait-score-value"}}
        {{formGroup fields.score.fields.max value=system.score.max classes="stacked" rootId="trait-score-max"}}
        {{else}}
        {{#if hasTraitChoices}}
        {{formGroup fields.intensity rootId="trait-intensity" classes="text-field" stacked=true value=system.intensity}}
        {{formGroup fields.choices value=system.choices classes="stacked" rootId="trait-choices" }}
        <div class="form-group stacked text-field">
            <label>Value</label>
            <div class="form-fields">
                <select class="value" name="system.textValue">
                    {{selectOptions system.choices selected=system.textValue}}
                </select>
            </div>
        </div>
        {{else}}
        {{formGroup fields.textValue rootId="trait-textvalue" classes="text-field" stacked=true value=system.textValue}}
        {{/if}}
        {{/if}}
    </div>

    {{!-- Value-description bands are measured-only (label each score range). --}}
    {{#if (eq system.subType "measured")}}

    <div class="list-section">
        <div class="list">
            <header class="list__header flexrow">
                <h3 class="list__name name">Value Desc</h3>
                <div class="detail ele">Max</div>
                <div class="list__controls">
                    <a class="list__control add-array-item" data-array="system.valueDesc" data-object-type="ValueDesc"
                        data-title="Add Value Description"><i class="fa-solid fa-plus"></i> Add</a>
                </div>
            </header>
            <ol class="list">
                {{#each system.valueDesc}}
                <li class="item flexrow">
                    <div class="list__name name">{{label}}</div>
                    <div class="detail ele">{{maxValue}}</div>
                    <div class="list__controls">
                        <a class="delete-array-item" data-array="system.valueDesc" data-index="{{@index}}"
                            title="Delete Value Description"><i class="fa-solid fa-trash"></i></a>
                    </div>
                </li>
                {{/each}}
            </ol>
        </div>
    </div>
    {{/if}}

    <div class="list-section">
        <div class="list">
            <header class="list__header flexrow">
                <h3 class="list__name name">Choice Label</h3>
                <div class="detail notes">Key</div>
                <div class="list__controls">
                    <a class="list__control add-object-key" data-object="system.choices"
                        data-title="Add Choice"><i class="fa-solid fa-plus"></i> Add</a>
                </div>
            </header>
            <ol class="list">
                {{#each idata.choices}}
                <li class="item flexrow">
                    <div class="list__name name" title="{{this}}">{{this}}</div>
                    <div class="detail notes" title="{{@key}}">{{@key}}</div>
                    <div class="list__controls">
                        <a class="delete-object-key" data-object="system.choices" data-key="{{@key}}"
                            title="Delete Choice"><i class="fa-solid fa-trash"></i></a>
                    </div>
                </li>
                {{/each}}
            </ol>
        </div>
    </div>
</section>
