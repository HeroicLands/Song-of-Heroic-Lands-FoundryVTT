<section class="tab properties" data-tab="properties">
    <fieldset>
        <legend>Gear</legend>
        <div class="grid grid-3col">
            {{formField fields.shortcode rootId="wpngear-shortcode" classes="text-field" stacked=true value=system.shortcode}}
            {{formField fields.quantity rootId="wpngear-quant" classes="text-field" stacked=true value=system.quantity}}
            {{formField fields.weightBase rootId="wpngear-wt" classes="text-field" stacked=true value=system.weightBase}}
            {{formField fields.valueBase rootId="wpngear-val" classes="text-field" stacked=true value=system.valueBase}}
            {{formField fields.isCarried rootId="wpngear-carried" classes="text-field" stacked=true value=system.isCarried}}
            {{formField fields.isEquipped rootId="wpngear-equipped" classes="text-field" stacked=true value=system.isEquipped}}
            {{formField fields.qualityBase rootId="wpngear-qual" classes="text-field" stacked=true value=system.qualityBase}}
            {{formField fields.durabilityBase rootId="wpngear-dur" classes="text-field" stacked=true value=system.durabilityBase}}
        </div>
    </fieldset>

    <div class="grid grid-3col">
        {{formField fields.lengthBase rootId="wpngear-lengthbase" classes="text-field" stacked=true value=system.lengthBase}}
    </div>
</section>
