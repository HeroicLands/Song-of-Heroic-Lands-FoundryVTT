<section class="tab properties" data-tab="properties">
    <fieldset>
        <legend>Strike Mode</legend>
        <div class="grid grid-3col">
            {{formField fields.shortcode rootId="mwsm-shortcode" classes="text-field" stacked=true value=system.shortcode}}
            {{formField fields.mode rootId="mwsm-mode" classes="text-field" stacked=true value=system.mode}}
            {{formField fields.minParts rootId="mwsm-minparts" classes="text-field" stacked=true value=system.minParts}}
            {{formField fields.assocSkillName rootId="mwsm-assocskill" classes="text-field" stacked=true value=system.assocSkillName}}
        </div>
    </fieldset>

    <fieldset>
        <legend>Impact</legend>
        <div class="grid grid-4col">
            {{formField fields.impactBase.fields.numDice rootId="mwsm-imp-numdice" classes="text-field" stacked=true value=system.impactBase.numDice}}
            {{formField fields.impactBase.fields.die rootId="mwsm-imp-die" classes="text-field" stacked=true value=system.impactBase.die}}
            {{formField fields.impactBase.fields.modifier rootId="mwsm-imp-mod" classes="text-field" stacked=true value=system.impactBase.modifier}}
            {{formField fields.impactBase.fields.aspect rootId="mwsm-imp-asp" classes="text-field" stacked=true value=system.impactBase.aspect}}
        </div>
    </fieldset>

    <div class="grid grid-3col">
        {{formField fields.lengthBase rootId="mwsm-lengthbase" classes="text-field" stacked=true value=system.lengthBase}}
    </div>
</section>
