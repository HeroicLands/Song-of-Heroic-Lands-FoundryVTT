<section class="tab properties{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="properties">
    <div class="grid grid-3col">
        {{formField fields.subType rootId="trauma-subtype" classes="text-field" stacked=true value=system.subType}}
        {{formField fields.levelBase rootId="trauma-level" classes="text-field" stacked=true value=system.levelBase}}
        {{formField fields.healingRateBase rootId="trauma-hr" classes="text-field" stacked=true value=system.healingRateBase}}
        {{#if (eq system.subType "physical")}}
        {{formField fields.aspect rootId="trauma-aspect" classes="text-field" stacked=true value=system.aspect}}
        {{formField fields.bodyLocationCode rootId="trauma-bodyloc" classes="text-field" stacked=true value=system.bodyLocationCode}}
        {{/if}}
        <div class="form-group text-field">
            {{clearableNumberInput fields.treatmentDate name="system.treatmentDate" value=system.treatmentDate}}
            <label>Treated (world-time)</label>
        </div>
        {{#if (eq system.subType "physical")}}
        <div class="form-group text-field">
            {{formInput fields.isBleeding rootId="trauma-bleeding" classes="form-fields" value=system.isBleeding}}
            <label>Bleeding</label>
        </div>
        {{/if}}
    </div>
</section>
