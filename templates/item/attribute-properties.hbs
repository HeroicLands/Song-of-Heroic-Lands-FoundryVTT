<section class="tab properties{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="properties">
    <div class="grid grid-3col">
        {{formGroup fields.scoreBase rootId="attribute-scorebase" classes="text-field" stacked=true value=system.scoreBase}}
        {{formGroup fields.initDiceFormula rootId="attribute-initdice" classes="text-field" stacked=true value=system.initDiceFormula}}
    </div>

    <div class="list-section">
        <div class="list">
            <header class="list__header flexrow">
                <h3 class="list__name name">Value Descriptors</h3>
                <div class="detail ele">Max Value</div>
                <div class="list__controls">
                    <a class="list__control add-array-item" data-array="system.valueDesc" data-object-type="ValueDesc"
                        data-title="Add Value Descriptor"><i class="fa-solid fa-plus"></i> Add</a>
                </div>
            </header>
            <ol class="list">
                {{#each valueDesc}}
                <li class="item flexrow">
                    <div class="list__name name">{{this.label}}</div>
                    <div class="detail ele">{{this.maxValue}}</div>
                    <div class="list__controls">
                        <a class="delete-array-item" data-array="system.valueDesc" data-index="{{@index}}"
                            title="Delete Value Descriptor"><i class="fa-solid fa-trash"></i></a>
                    </div>
                </li>
                {{else}}
                <li class="item flexrow">
                    <div class="list__name name">—</div>
                </li>
                {{/each}}
            </ol>
        </div>
    </div>

    <div class="list-section">
        <div class="list">
            <header class="list__header flexrow">
                <h3 class="list__name name">Impaired By Roles</h3>
                <div class="list__controls">
                    <a class="list__control add-array-item" data-array="system.impairedByRoles" data-dtype="String"
                        data-default-value="" data-title="Impaired By Role"><i class="fa-solid fa-plus"></i> Add</a>
                </div>
            </header>
            <ol class="list">
                {{#each impairedByRoles}}
                <li class="item flexrow">
                    <div class="list__name name">{{this}}</div>
                    <div class="list__controls">
                        <a class="delete-array-item" data-array="system.impairedByRoles" data-value="{{this}}"
                            title="Delete Role"><i class="fa-solid fa-trash"></i></a>
                    </div>
                </li>
                {{else}}
                <li class="item flexrow">
                    <div class="list__name name">—</div>
                </li>
                {{/each}}
            </ol>
        </div>
    </div>
</section>
