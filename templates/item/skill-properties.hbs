<section class="tab properties{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="properties">
    <div class="grid grid-3col">
        {{formField fields.skillBaseFormula rootId="skill-sbf" classes="text-field" stacked=true value=system.skillBaseFormula}}
        {{formField fields.masteryLevelBase rootId="skill-mlb" classes="text-field" stacked=true value=system.masteryLevelBase}}
        {{formField fields.improveFlag rootId="skill-improve" classes="text-field" stacked=true value=system.improveFlag}}
        {{formField fields.weaponGroup rootId="skill-wpngrp" classes="text-field" stacked=true value=system.weaponGroup}}
        {{formField fields.baseSkill rootId="skill-baseskill" classes="text-field" stacked=true value=system.baseSkill}}
        {{formField fields.domain rootId="skill-domain" classes="text-field" stacked=true value=system.domain}}
    </div>

    {{!--
      Combat-technique strike mode. Shown only for the `combattechnique`
      subtype. `strikeMode` is a discriminated TypedSchemaField (melee/missile)
      stored flat as `{ type, ...fields }`, so its sub-fields are edited at
      explicit `system.strikeMode.<field>` paths; a hidden `type` input keeps the
      discriminated update valid on submit. A technique's Atk/Blk/CX derive from
      this skill's own mastery level unless the optional override code is set.
    --}}
    {{#if isCombatTechnique}}
    <input type="hidden" name="system.strikeMode.type" value="{{smType}}" />

    <fieldset>
        <legend>Strike Mode ({{smType}})</legend>
        <div class="grid grid-2col">
            <label class="form-group stacked"><span>Name</span>
                <input type="text" name="system.strikeMode.name" value="{{sm.name}}" /></label>
            <label class="form-group stacked"><span>Min Parts</span>
                <input type="number" name="system.strikeMode.minParts" value="{{sm.minParts}}" /></label>
            <label class="form-group stacked"><span>Governing Skill Override</span>
                <input type="text" name="system.strikeMode.assocSkillCode" value="{{sm.assocSkillCode}}"
                    data-tooltip="Optional. Leave blank to use this skill's own mastery level; set to another skill's code to borrow its mastery level." /></label>
            {{#if isMelee}}
            <label class="form-group stacked"><span>Length</span>
                <input type="number" step="0.1" name="system.strikeMode.lengthBase" value="{{sm.lengthBase}}" /></label>
            {{/if}}
            {{#if isMissile}}
            <label class="form-group stacked"><span>Projectile Type</span>
                <input type="text" name="system.strikeMode.projectileType" value="{{sm.projectileType}}" /></label>
            <label class="form-group stacked"><span>Base Range</span>
                <input type="number" name="system.strikeMode.baseRangeBase" value="{{sm.baseRangeBase}}" /></label>
            <label class="form-group stacked"><span>Draw</span>
                <input type="number" name="system.strikeMode.drawBase" value="{{sm.drawBase}}" /></label>
            <label class="form-group stacked"><span>Max Volley ×</span>
                <input type="number" name="system.strikeMode.maxVolleyMult" value="{{sm.maxVolleyMult}}" /></label>
            {{/if}}
        </div>
    </fieldset>

    <fieldset>
        <legend>Attack</legend>
        <div class="grid grid-2col">
            <label class="form-group stacked"><span>Spread</span>
                <input type="number" name="system.strikeMode.attack.spread" value="{{sm.attack.spread}}" /></label>
            <label class="form-group stacked"><span>Attack Modifier</span>
                <input type="number" name="system.strikeMode.attack.modifier" value="{{sm.attack.modifier}}" /></label>
        </div>
    </fieldset>

    <fieldset>
        <legend>Impact</legend>
        <div class="grid grid-3col">
            <label class="form-group stacked"><span>Dice</span>
                <input type="number" name="system.strikeMode.impactBase.numDice" value="{{sm.impactBase.numDice}}" /></label>
            <label class="form-group stacked"><span>Die</span>
                <input type="number" name="system.strikeMode.impactBase.die" value="{{sm.impactBase.die}}" /></label>
            <label class="form-group stacked"><span>Modifier</span>
                <input type="number" name="system.strikeMode.impactBase.modifier" value="{{sm.impactBase.modifier}}" /></label>
        </div>
    </fieldset>

    {{#if isMelee}}
    <fieldset>
        <legend>Defense</legend>
        <div class="grid grid-2col">
            <label class="form-group stacked"><span>Block Modifier</span>
                <input type="number" name="system.strikeMode.defense.block.modifier" value="{{sm.defense.block.modifier}}" /></label>
            <label class="form-group stacked"><span>Counterstrike Modifier</span>
                <input type="number" name="system.strikeMode.defense.counterstrike.modifier" value="{{sm.defense.counterstrike.modifier}}" /></label>
        </div>
    </fieldset>
    {{/if}}
    {{/if}}
</section>
