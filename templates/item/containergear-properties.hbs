<section class="tab properties{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="properties">
    <fieldset>
        <legend>Gear</legend>
        <div class="grid grid-3col">
            {{formGroup fields.quantity rootId="contgear-quant" classes="text-field" stacked=true value=system.quantity}}
            {{formGroup fields.weightBase rootId="contgear-wt" classes="text-field" stacked=true value=system.weightBase}}
            {{formGroup fields.valueBase rootId="contgear-val" classes="text-field" stacked=true value=system.valueBase}}
            {{formGroup fields.isCarried rootId="contgear-carried" classes="text-field" stacked=true value=system.isCarried}}
            {{formGroup fields.isEquipped rootId="contgear-equipped" classes="text-field" stacked=true value=system.isEquipped}}
            {{formGroup fields.qualityBase rootId="contgear-qual" classes="text-field" stacked=true value=system.qualityBase}}
            {{formGroup fields.durabilityBase rootId="contgear-dur" classes="text-field" stacked=true value=system.durabilityBase}}
        </div>
    </fieldset>

    <div class="grid grid-3col">
        {{formGroup fields.maxCapacityBase rootId="contgear-maxcap" classes="text-field" stacked=true value=system.maxCapacityBase}}
    </div>
</section>
