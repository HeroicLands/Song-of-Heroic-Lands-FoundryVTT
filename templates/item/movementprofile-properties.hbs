<section class="tab properties" data-tab="properties">
    <div class="grid grid-3col">
        {{formField fields.shortcode rootId="mvmt-shortcode" classes="text-field" stacked=true value=system.shortcode}}
        {{formField fields.medium rootId="mvmt-medium" classes="text-field" stacked=true value=system.medium}}
        {{formField fields.metersPerRound rootId="mvmt-mpr" classes="text-field" stacked=true value=system.metersPerRound}}
        {{formField fields.metersPerWatch rootId="mvmt-mpw" classes="text-field" stacked=true value=system.metersPerWatch}}
        {{formField fields.disabled rootId="mvmt-disabled" classes="text-field" stacked=true value=system.disabled}}
    </div>
</section>
