<section class="tab properties{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="properties">
    <fieldset>
        <legend>Gear</legend>
        <div class="grid grid-3col">
            {{formGroup fields.quantity rootId="miscgear-quant" classes="text-field" stacked=true value=system.quantity}}
            {{formGroup fields.weightBase rootId="miscgear-wt" classes="text-field" stacked=true value=system.weightBase}}
            {{formGroup fields.valueBase rootId="miscgear-val" classes="text-field" stacked=true value=system.valueBase}}
            {{formGroup fields.isCarried rootId="miscgear-carried" classes="text-field" stacked=true value=system.isCarried}}
            {{formGroup fields.isEquipped rootId="miscgear-equipped" classes="text-field" stacked=true value=system.isEquipped}}
            {{formGroup fields.qualityBase rootId="miscgear-qual" classes="text-field" stacked=true value=system.qualityBase}}
            {{formGroup fields.durabilityBase rootId="miscgear-dur" classes="text-field" stacked=true value=system.durabilityBase}}
        </div>
    </fieldset>
</section>
