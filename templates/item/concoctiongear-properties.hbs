<section class="tab properties{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="properties">
    <fieldset>
        <legend>Gear</legend>
        <div class="grid grid-3col">
            {{formGroup fields.quantity rootId="concgear-quant" classes="text-field" stacked=true value=system.quantity}}
            {{formGroup fields.weightBase rootId="concgear-wt" classes="text-field" stacked=true value=system.weightBase}}
            {{formGroup fields.valueBase rootId="concgear-val" classes="text-field" stacked=true value=system.valueBase}}
            {{formGroup fields.isCarried rootId="concgear-carried" classes="text-field" stacked=true value=system.isCarried}}
            {{formGroup fields.isEquipped rootId="concgear-equipped" classes="text-field" stacked=true value=system.isEquipped}}
            {{formGroup fields.qualityBase rootId="concgear-qual" classes="text-field" stacked=true value=system.qualityBase}}
            {{formGroup fields.durabilityBase rootId="concgear-dur" classes="text-field" stacked=true value=system.durabilityBase}}
        </div>
    </fieldset>

    <div class="grid grid-3col">
        {{formGroup fields.potency rootId="concgear-potency" classes="text-field" stacked=true value=system.potency}}
        {{formGroup fields.strength rootId="concgear-strength" classes="text-field" stacked=true value=system.strength}}
    </div>
</section>
