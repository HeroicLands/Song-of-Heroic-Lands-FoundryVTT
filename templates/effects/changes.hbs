<section class="tab changes{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="{{tab.id}}">
    <header>
        <div class="key">{{localize "EFFECT.FIELDS.changes.element.key.label"}}</div>
        <div class="type">{{localize "EFFECT.FIELDS.changes.element.type.label"}}</div>
        <div class="value">{{localize "EFFECT.FIELDS.changes.element.value.label"}}</div>
        <div class="priority">{{localize "EFFECT.FIELDS.changes.element.priority.label"}}</div>
        <div class="controls">
            <button type="button" class="inline-control icon sohl-add" data-action="addChange"></button>
        </div>
    </header>
    <ol class="scrollable" data-changes>
        {{#each document.system.changes as |change i|}}
        <li data-index="{{i}}">
            <div class="key">
                <select name="system.changes.{{i}}.key" data-dtype="String">
                    {{selectOptions ../keyChoices selected=change.key labelAttr="label"}}
                </select>
            </div>
            <div class="type">
                <select name="system.changes.{{i}}.type" data-dtype="String">
                    {{selectOptions ../changeTypes selected=change.type}}
                </select>
            </div>
            <div class="value">
                <input type="text" name="system.changes.{{i}}.value" value="{{change.value}}"/>
            </div>
            <div class="priority">
                <input type="number" name="system.changes.{{i}}.priority" value="{{change.priority}}"
                    placeholder="{{../defaultPriority}}"/>
            </div>
            <div class="controls">
                <button type="button" class="inline-control icon sohl-trash" data-action="deleteChange"></button>
            </div>
            {{#if (isSmKey ../scope change.key)}}
            <div class="strike-mode-predicate" style="grid-column: 1 / -1;">
                <label>
                    <span>{{localize "SOHL.ActiveEffect.FIELDS.changes.element.strikeModePredicate.label"}}</span>
                    <textarea name="system.changes.{{i}}.strikeModePredicate"
                        rows="2"
                        placeholder="sm.type === 'melee'">{{change.strikeModePredicate}}</textarea>
                </label>
                <p class="hint">{{localize "SOHL.ActiveEffect.FIELDS.changes.element.strikeModePredicate.hint"}}</p>
            </div>
            {{/if}}
        </li>
        {{/each}}
    </ol>
</section>
