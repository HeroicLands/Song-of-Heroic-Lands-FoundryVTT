<div class="tab scrollable{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="{{tab.id}}">
    <fieldset>
        <legend>{{localize "SOHL.Scene.SHEET.tab.sohl.label"}}</legend>
        <div class="form-group">
            <label for="{{rootId}}-system.isTotm">
                {{localize "SOHL.Scene.FIELDS.isTotm.label"}}
            </label>
            <div class="form-fields">
                <input type="checkbox"
                       id="{{rootId}}-system.isTotm"
                       name="system.isTotm"
                       {{#if source.system.isTotm}}checked{{/if}}>
            </div>
            <p class="hint">{{localize "SOHL.Scene.FIELDS.isTotm.hint"}}</p>
        </div>
    </fieldset>
</div>
