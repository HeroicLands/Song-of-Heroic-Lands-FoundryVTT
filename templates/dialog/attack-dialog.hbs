{{!--
    Automated-combat attack dialog. The Weapon Aspect is derived from the
    strike mode (it is not chosen here); the attacker only picks the Aim
    (the target body part) and an Additional Modifier. Both choices are echoed
    onto the attack chat card for transparency.
--}}
<form>
    <div class="form-group">
        <label>Aim:</label>
        <select name="aim">
            {{selectOptions aimChoices selected=defaultAim}}
        </select>
    </div>

    <div class="form-group">
        <label>Additional Modifier:</label>
        <input
            type="number"
            name="situationalModifier"
            value="{{situationalModifier}}"
        />
    </div>
</form>
