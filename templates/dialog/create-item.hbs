<form id="document-create item-create" autocomplete="off">
    <div class="form-group" id="type-group"{{#unless askType}} style="display:none"{{/unless}}>
        <label>Type</label>
        <div class="form-fields">
            <select name="type" autofocus>
                {{selectOptions types selected=type}}
            </select>
        </div>
    </div>

    {{#if hasFolders}}
    <div class="form-group">
        <label>Folder</label>
        <div class="form-fields">
            <select name="folder">
                {{selectOptions folders selected=folder valueAttr="id"
                labelAttr="name" blank=""}}
            </select>
        </div>
    </div>
    {{/if}}

    <div class="form-group" id="subtypes"{{#unless hasSubtypes}} style="display:none"{{/unless}}>
        <label>Subtypes</label>
        <div class="form-fields">
            <select
                class="resource-value"
                id="subtype-select"
                name="subtype"
                data-dtype="String">
                {{selectOptions subtypes selected=subtype}}
            </select>
        </div>
    </div>

    <div class="form-group" id="archetypes">
        <label>Archetype</label>
        <div class="form-fields">
            <select
                id="archetype-select"
                name="archetype"
                data-dtype="String"
                data-tooltip="Start from a populated template, or choose (none) for a blank document.">
                {{selectOptions archetypes selected=archetype}}
            </select>
        </div>
    </div>

    <div class="form-group">
        <label>Name</label>
        <div class="form-fields">
            <input
                type="text"
                name="name"
                value="{{name}}"
                placeholder="{{defaultName}}"
                data-tooltip="Optional — defaults to the chosen archetype's name." />
        </div>
    </div>

    {{#if showShortcode}}
    <div class="form-group" id="shortcode-group">
        <label>Shortcode</label>
        <div class="form-fields">
            <input
                type="text"
                name="shortcode"
                value="{{shortcode}}"
                data-tooltip="Optional — a short, unique code; defaults to the chosen archetype's (or the name)." />
        </div>
    </div>
    {{/if}}
</form>
