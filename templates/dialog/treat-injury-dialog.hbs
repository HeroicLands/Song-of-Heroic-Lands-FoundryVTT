{{!--
Treat Injury dialog. Gathers the Healing Rate to record on a wound when the
`treatInjury` action is run by hand (no card to pre-fill it). The card path
supplies the same value in data-scope with skipDialog, so this dialog never
opens there.
--}}
<form>
    <div class="form-group">
        <label>Healing Rate:</label>
        <input type="number" name="healingRate" value="{{healingRate}}" min="0" step="1" />
    </div>
    <p class="hint">The wound's treated Healing Rate (0 heals it outright).</p>
</form>
