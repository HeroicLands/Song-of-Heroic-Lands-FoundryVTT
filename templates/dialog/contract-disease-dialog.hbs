<form>
    <div class="form-group">
        <label>Disease:</label>
        <select name="selection">
            {{selectOptions afflictions valueAttr="index" labelAttr="name"}}
            <option value="{{customValue}}">— Custom disease —</option>
        </select>
    </div>

    <fieldset class="contract-disease-custom">
        <legend>Custom disease</legend>
        <p class="hint">
            Used only when “— Custom disease —” is selected above.
        </p>

        <div class="grid grid-2col">
            <div class="form-group">
                <label>Name:</label>
                <input type="text" name="customName" value="" />
            </div>

            <div class="form-group" data-tooltip="Contagion index (1–5); lower is more contagious">
                <label>Contagion Index:</label>
                <input type="number" name="customCI" value="1" min="1" max="5" />
            </div>
        </div>
    </fieldset>
</form>
