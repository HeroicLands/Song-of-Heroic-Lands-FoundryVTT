{{!--
Treatment Requested card body (spoken by the patient). The patient asks a
physician to treat a wound; the appended open [Perform Treatment Test] button
(added by buildActionCard) is answerable by any player whose default character
has the Physician skill. Body only — no buttons here.
--}}
<div class="chat-card">
    <header class="card-header flexrow">
        <h3 class="title">Treatment Requested</h3>
    </header>

    <div class="card-content center">
        <span>{{patientName}} asks a physician to treat {{woundName}}.</span>
    </div>

    <div class="grid grid-2col flex-center">
        <div class="card-content flexrow">
            <span class="label">Aspect:</span>
            <span class="value">{{aspect}}</span>
        </div>
        <div class="card-content flexrow">
            <span class="label">Severity:</span>
            <span class="value">{{severity}}</span>
        </div>
    </div>
</div>
