<div class="hmk chat-card item-card" data-actor-id="{{actorId}}">
    <header class="card-header flexrow">
        <h3 class="title">Rally!</h3>
    </header>

    <div class="card-content center">
        <span>{{rallierName}} rallies shaken allies.</span>
    </div>

    <div class="card-content center">
        {{#if steady}}
        <span>A Routed or Withdrawing ally may steady themselves.</span>
        {{else}}
        <span
            >A Routed or Withdrawing ally may make a Reaction Test to
            steady.</span
        >
        {{/if}}
    </div>
</div>
