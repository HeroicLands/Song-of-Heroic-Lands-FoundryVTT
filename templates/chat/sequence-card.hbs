{{!--
Generic Chat Sequence card. Rendered by the sequence runtime for each step of a
running interaction. Each button advances the sequence via the shared chat-card
dispatch chokepoint: it carries the sequence coordinates (sequenceId / stepId /
choiceKey), the acting role's handler uuid (the ownership gate), and the
serialized instance ledger in data-scope.
--}}

<div class="hmk chat-card sequence-card" data-sequence-id="{{sequenceId}}">
    <header class="card-header">
        <h3 class="title">{{title}}</h3>
    </header>

    {{#if body}}
    <div class="card-content">
        <p>{{body}}</p>
    </div>
    {{/if}}

    <div class="card-buttons">
        {{#each buttons}}
        <button
            data-action="{{this.action}}"
            data-sequence-id="{{../sequenceId}}"
            data-step-id="{{../stepId}}"
            data-choice-key="{{this.choiceKey}}"
            data-handler-uuid="{{../handlerUuid}}"
            data-scope="{{toJSON ../scopeData}}">
            {{#if this.iconFAClass}}<i class="{{this.iconFAClass}}"></i> {{/if}}{{this.label}}
        </button>
        {{/each}}
    </div>
</div>
