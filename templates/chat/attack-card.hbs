{{!--
    Automated-combat attack card (spoken by the attacker).

    Transparency-by-design: the attacker's Aim and Aspect choices and the
    resolved Attack Mastery Level are shown so every player can verify the
    parameters of the attack.

    The whole evaluated AttackResult is embedded (kind-stamped) in each defense
    button's `data-attack-result-json`, serialized with the registered `toJSON`
    helper. The defender's client rehydrates it with `instanceFromJSON`. The Aim
    is carried separately in `data-aim` so it survives to the defense resume and
    the injury card. The defense buttons dispatch to the defender's actor (via
    `data-handler-actor-uuid`) so the chosen defense resolves on the defender's
    client.
--}}
<div class="hmk chat-card item-card" data-actor-id="{{actorId}}">
    <header class="card-header">
        <h3 class="title">{{title}}</h3>
        <h4 class="subtitle">{{attackerName}} vs. {{defenderName}}</h4>
    </header>

    <div class="grid grid-2col">
        <div class="card-content">
            <span class="label">Aim:</span>
            <span class="value">{{aimLabel}}</span>
        </div>

        <div class="card-content">
            <span class="label">Aspect:</span>
            <span class="value">{{aspect}}</span>
        </div>
    </div>

    <div class="card-content center">
        <span class="label">AML:</span>
        <span class="value">{{aml}}</span>
    </div>

    {{#if (or hasDodge hasCounterstrike hasBlock hasIgnore)}}
    <div class="card-buttons">
        <div class="grid grid-2col mingap">
            {{#if hasDodge}}
            <button
                id="dodge-button"
                data-action="automatedDodgeResume"
                data-handler-actor-uuid="{{handlerActorUuid}}"
                data-aim="{{aim}}"
                data-attack-result-json="{{toJSON attackResultData}}"
            >
                Dodge
            </button>
            {{/if}}
            {{#if hasCounterstrike}}
            <button
                id="counterstrike-button"
                data-action="automatedCounterstrikeResume"
                data-handler-actor-uuid="{{handlerActorUuid}}"
                data-aim="{{aim}}"
                data-attack-result-json="{{toJSON attackResultData}}"
            >
                Counterstrike
            </button>
            {{/if}}
            {{#if hasBlock}}
            <button
                id="block-button"
                data-action="automatedBlockResume"
                data-handler-actor-uuid="{{handlerActorUuid}}"
                data-aim="{{aim}}"
                data-attack-result-json="{{toJSON attackResultData}}"
            >
                Block
            </button>
            {{/if}}
            {{#if hasIgnore}}
            <button
                id="ignore-button"
                data-action="automatedIgnoreResume"
                data-handler-actor-uuid="{{handlerActorUuid}}"
                data-aim="{{aim}}"
                data-attack-result-json="{{toJSON attackResultData}}"
            >
                Ignore
            </button>
            {{/if}}
        </div>
    </div>
    {{/if}}
</div>
