{{!--
Generic action-card button block, appended to a card body by
`buildActionCard`. Each button is a pre-filled invocation of a self-sufficient
action, dispatched through the shared chat-card chokepoint: it carries the
action name (data-action), the handler (data-handler-uuid — a document uuid, or
the "@self" sentinel for an open button), the action's parameters
(data-scope, pre-serialized), and data-skip-dialog so the click runs the action
without re-prompting. The `action-card-button` class marks it for render-time
targeted-vs-open gating (`gateActionCardButtons`).
--}}
<div class="card-buttons">
    {{#each buttons}}
    <button
        class="action-card-button"
        data-action="{{this.action}}"
        data-handler-uuid="{{this.handlerUuid}}"
        data-scope="{{this.scopeJSON}}"
        data-skip-dialog="{{this.skipDialog}}">
        {{#if this.iconFAClass}}<i class="{{this.iconFAClass}}"></i> {{/if}}{{this.label}}
    </button>
    {{/each}}
</div>
