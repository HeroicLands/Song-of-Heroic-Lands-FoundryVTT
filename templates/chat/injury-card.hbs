<div class="hmk chat-card item-card" data-actor-id="{{actorId}}">
    <header class="card-header">
        <h3 class="title">{{bodyZoneName}} Injury</h3>
        <h4 class="subtitle">{{name}}</h4>
    </header>

    <div class="card-content center">
        <div class="flexrow">
            <span class="label">Body Part:</span>
            <span class="value">{{bodyPartName}}</span>
        </div>
    </div>

    <div class="card-content center">
        <div class="flexrow">
            <span class="label">Aspect:</span>
            <span class="value">{{aspect}}</span>
        </div>
    </div>

    {{#if armorReduction}}
    <div class="card-content center">
        <div class="flexrow">
            <span class="label">Armor Reduction:</span>
            <span class="value">{{armorReduction}}</span>
            <span class="note"
                >Armor value has been reduced by<br />Armor Reduction
                value</span
            >
        </div>
    </div>
    {{/if}}

    <div class="card-content center">
        <div class="flexrow">
            <span class="label">Armor Layers (prot):</span>
            <span class="value">{{#if armorType}}{{armorType}}{{else}}None{{/if}} ({{armorValue}})</span>
        </div>
    </div>

    <div class="card-content center">
        <div class="flexrow">
            <span class="label">Impact:</span>
            <span class="value"><strong>{{impactVal}}</strong></span>
        </div>
    </div>

    {{#if isGlancingBlow}}
    <div class="card-content center">
        <div class="flexrow">
            <span class="note success-test"
                >Rigid armor minimizes impact.<br />Glancing Blow!</span
            >
        </div>
    </div>
    {{/if}}

    {{#unless isInjured}}
    <div class="card-content center">
        <div class="flexrow">
            <span class="label">Injury Level:</span>
            <span class="value success-text">No Injury</span>
        </div>
    </div>
    {{else}}
    <div class="card-content center">
        <div class="flexrow">
            <span class="label">Injury Level:</span>
            <span class="value failure-text">{{injuryLevelText}}</span>
        </div>
    </div>
    {{/unless}}

    {{#if needsShockRoll}}
    <div class="card-content center">
        <div class="flexrow">
            <span class="label">Shock Index:</span>
            <span class="value">{{shockIndex}}</span>
        </div>
        <div class="flexrow">
            <span class="note failure-text">Make a Shock roll!</span>
        </div>
        {{#if shockRollBonus}}
        <div class="flexrow">
            <span class="note">+{{shockRollBonus}} to the Shock roll (glancing blow).</span>
        </div>
        {{/if}}
    </div>
    {{else}}
    <div class="card-content center">
        <div class="flexrow">
            <span class="label">Shock Index:</span>
            <span class="value">{{shockIndex}}</span>
        </div>
        <div class="flexrow">
            <span class="note">Shock roll not needed</span>
        </div>
    </div>
    {{/if}}

    {{#if isBleeder}}
    <div class="card-content center">
        <span class="note failure-text">NOTE: Injury is a bleeder</span>
    </div>
    {{/if}}

    {{#unless (eq fumble "none")}}
    <div class="card-content center">
        {{#if (eq fumble "auto")}}
        <span class="note failure-text">Grievous Mishap: Fumbles (automatic)</span>
        {{else}}
        <span class="note failure-text">Mishap: roll to avoid a Fumble</span>
        {{/if}}
    </div>
    {{/unless}}

    {{#unless (eq stumble "none")}}
    <div class="card-content center">
        {{#if (eq stumble "auto")}}
        <span class="note failure-text">Grievous Mishap: Stumbles (automatic)</span>
        {{else}}
        <span class="note failure-text">Mishap: roll to avoid a Stumble</span>
        {{/if}}
    </div>
    {{/unless}}

    {{#if canAmputate}}
    <div class="card-content center">
        <span class="note failure-text"
            >NOTE: Perform Strength test<br />
            {{#if amputationModifier}} with a {{amputationModifier}} modifier<br />
            {{/if}} to determine if limb is amputated<br />
            (you will have to make this roll manually).</span
        >
    </div>
    {{/if}}

    {{#if addToCharSheet}}
    <div class="card-content center">
        <span>Injury recorded on character sheet</span>
    </div>
    {{/if}}

    <div class="card-buttons">
        {{#if needsShockRoll}}
        <button
            data-action="shock"
            data-handler-uuid="{{handlerActorUuid}}"
            data-shock-index="{{shockIndex}}"
            data-shock-bonus="{{shockRollBonus}}">
            Shock Roll
        </button>
        {{/if}}
    </div>
</div>
