<div class="chat-card">
    <header class="card-header flexrow">
        <h3 class="title">Blood Stoppage Result</h3>
    </header>

    {{#if physicianName}}
    <div class="card-content center">
        <span>{{physicianName}} attempted to staunch {{woundName}}.</span>
    </div>
    {{/if}}

    <div class="card-content center">
        <span class="value {{#if stopped}}success-text{{else}}failure-text{{/if}}"
            >{{outcomeLabel}}</span
        >
    </div>
</div>
