<form autocomplete="off">

    <!-- Effect Header -->
    <header class="sheet-header">
        <img class="effect-img" src="{{ data.img }}" data-edit="img" />
        <h1 class="effect-title">
            <input name="name" type="text" value="{{data.name}}" placeholder="{{ localize 'Name' }}"/>
        </h1>
    </header>

    <!-- Effect Configuration Tabs -->
    <nav class="sheet-tabs tabs" aria-role="{{localize 'SHEETS.FormNavLabel'}}">
        <a class="item" data-tab="details"><i class="fas fa-book"></i> {{localize "EFFECT.TabDetails"}}</a>
        <a class="item" data-tab="duration"><i class="fas fa-clock"></i> {{localize "EFFECT.TabDuration"}}</a>
        <a class="item" data-tab="effects"><i class="fas fa-cogs"></i> {{localize "EFFECT.TabEffects"}}</a>
    </nav>

    <!-- Details Tab -->
    <section class="tab" data-tab="details">
        <div class="form-group">
            <label>{{ localize "EFFECT.Tint" }}</label>
            <div class="form-fields">
                <color-picker name="tint" value="{{data.tint}}" placeholder="#ffffff"></color-picker>
            </div>
        </div>

        <div class="form-group stacked">
            <label>{{ localize "EFFECT.Description" }}</label>
            {{editor descriptionHTML target="description" button=false editable=editable engine="prosemirror" collaborate=false}}
        </div>

        <div class="form-group">
            <label>{{ localize "EFFECT.Disabled" }}</label>
            <input type="checkbox" name="disabled" {{ checked data.disabled }}/>
        </div>

        {{#if isActorEffect}}
        <div class="form-group">
            <label>{{ localize "EFFECT.Origin" }}</label>
            <div class="form-fields">
                <input type="text" name="origin" value="{{ data.sourceName }}" disabled/>
            </div>
        </div>
        {{/if}}

        <div class="form-group">
            <label>Target Type</label>
            <div class="form-fields">
                <select name="data.system.targetType" data-dtype="String">
                    {{selectOptions targetTypes selected=data.system.targetType}}
                </select>
            </div>
        </div>

        <div class="form-group">
            <label>Target Name</label>
            <div class="form-fields" data-tooltip="Can use the wildcard characters *, ?, or []; or use a regular expression if it starts with 'regex:'">
                <input type="text" name="data.system.targetName" value="{{ data.system.targetName }}" data-dtype="String" />
            </div>
        </div>

        <div class="form-group">
            <label>Status Conditions</label>
            <div class="form-fields">
                <multi-select name="statuses">
                    {{#each statuses as |status|}}
                    <option value="{{status.id}}" {{status.selected}}>{{status.label}}</option>
                    {{/each}}
                </multi-select>
            </div>
        </div>
    </section>

    <!-- Duration Tab (v14: duration.value + duration.units + start.*) -->
    <section class="tab" data-tab="duration">
        <div class="form-group">
            <label>{{ localize "EFFECT.DurationValue" }}</label>
            <div class="form-fields">
                <input type="number" name="duration.value" value="{{ data.duration.value }}" min="0" placeholder="None"/>
            </div>
        </div>
        <div class="form-group">
            <label>{{ localize "EFFECT.DurationUnits" }}</label>
            <div class="form-fields">
                <select name="duration.units" data-dtype="String">
                    <option value="seconds" {{#if (eq data.duration.units "seconds")}}selected{{/if}}>{{ localize "TIME.Second.other" }}</option>
                    <option value="rounds" {{#if (eq data.duration.units "rounds")}}selected{{/if}}>{{ localize "COMBAT.Rounds" }}</option>
                    <option value="turns" {{#if (eq data.duration.units "turns")}}selected{{/if}}>{{ localize "COMBAT.Turns" }}</option>
                </select>
            </div>
        </div>
        <div class="form-group">
            <label>{{ localize "EFFECT.Expiry" }}</label>
            <div class="form-fields">
                <select name="duration.expiry" data-dtype="String">
                    <option value="" {{#unless data.duration.expiry}}selected{{/unless}}>{{ localize "None" }}</option>
                    <option value="turnStart" {{#if (eq data.duration.expiry "turnStart")}}selected{{/if}}>Turn Start</option>
                    <option value="turnEnd" {{#if (eq data.duration.expiry "turnEnd")}}selected{{/if}}>Turn End</option>
                    <option value="roundStart" {{#if (eq data.duration.expiry "roundStart")}}selected{{/if}}>Round Start</option>
                    <option value="roundEnd" {{#if (eq data.duration.expiry "roundEnd")}}selected{{/if}}>Round End</option>
                    <option value="combatEnd" {{#if (eq data.duration.expiry "combatEnd")}}selected{{/if}}>Combat End</option>
                </select>
            </div>
        </div>
        <hr/>
        <div class="form-group">
            <label>{{ localize "EFFECT.StartTime" }}</label>
            <div class="form-fields">
                <input type="number" name="start.time" value="{{ data.start.time }}" disabled/>
            </div>
        </div>
        <div class="form-group">
            <label>{{ localize "EFFECT.StartTurns" }}</label>
            <div class="form-fields">
                <label>{{ localize "COMBAT.Round" }}</label>
                <input type="number" name="start.round" value="{{ data.start.round }}" disabled/>
                <label>{{ localize "COMBAT.Turn" }}</label>
                <input type="number" name="start.turn" value="{{ data.start.turn }}" disabled/>
            </div>
        </div>
    </section>

    <!-- Effects Tab (v14: system.changes with string type) -->
    <section class="tab" data-tab="effects">
        <header class="effect-change effects-header flexrow">
            <div class="key">{{ localize "EFFECT.ChangeKey" }}</div>
            <div class="type">{{ localize "EFFECT.ChangeType" }}</div>
            <div class="value">{{ localize "EFFECT.ChangeValue" }}</div>
            <div class="effect-controls">
                <a class="effect-control" data-action="add"><i class="far fa-plus-square"></i></a>
            </div>
        </header>
        <ol class="changes-list">
            {{#each data.system.changes as |change i|}}
            <li class="effect-change flexrow" data-index="{{i}}">
                <div class="key">
                    <select name="system.changes.{{i}}.key" data-dtype="String">
                        {{selectOptions ../keyChoices selected=change.key labelAttr="label"}}
                    </select>
                </div>
                <div class="type">
                    <select name="system.changes.{{i}}.type" data-dtype="String">
                        {{selectOptions ../changeTypes selected=change.type}}
                    </select>
                </div>
                <div class="value">
                    <input type="text" name="system.changes.{{i}}.value" value="{{change.value}}"/>
                </div>
                <div class="effect-controls">
                    <a class="effect-control" data-action="delete"><i class="fas fa-trash"></i></a>
                </div>
            </li>
            {{/each}}
        </ol>
    </section>

    <footer class="sheet-footer">
        <button type="submit"><i class="fas fa-save"></i> {{localize submitText}}</button>
    </footer>
</form>
