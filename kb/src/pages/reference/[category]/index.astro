---
import { getCollection } from "astro:content";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { REFERENCE_TYPES, byCategory } from "../../../reference/registry";

export async function getStaticPaths() {
    return REFERENCE_TYPES.map((t) => ({ params: { category: t.category } }));
}

const def = byCategory.get(Astro.params.category)!;
const entries = (
    await getCollection(
        "content",
        (e) => e.data.package === "sohl" && e.data.type === def.type,
    )
)
    .map((e) => ({
        name: e.data.name.full,
        slug: e.data.slug ?? e.id.split("/").pop()!,
        description: e.data.description,
    }))
    .sort((a, b) => a.name.localeCompare(b.name));
---

<StarlightPage frontmatter={{ title: def.title }}>
    <p>{def.blurb} — {entries.length} entries.</p>
    <ul>
        {
            entries.map((x) => (
                <li>
                    <a href={`/reference/${def.category}/${x.slug}/`}>
                        {x.name}
                    </a>
                    {x.description ? ` — ${x.description}` : ""}
                </li>
            ))
        }
    </ul>
</StarlightPage>
