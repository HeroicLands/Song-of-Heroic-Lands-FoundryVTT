---
import { getCollection, render } from "astro:content";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import Infobox from "../../../components/Infobox.astro";
import { REFERENCE_TYPES, byType } from "../../../reference/registry";

export async function getStaticPaths() {
    const cat = new Map(REFERENCE_TYPES.map((t) => [t.type, t.category]));
    const entries = await getCollection(
        "content",
        (e) => e.data.package === "sohl" && cat.has(e.data.type),
    );
    return entries.map((entry) => ({
        params: {
            category: cat.get(entry.data.type)!,
            slug: entry.data.slug ?? entry.id.split("/").pop()!,
        },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const def = byType.get(entry.data.type)!;
// Validate the entry's sohl block; a malformed entry fails the build.
const sohl = def.schema.parse(entry.data.sohl);
const rows = def.rows(sohl as Record<string, unknown>);
const { Content } = await render(entry);
---

<StarlightPage
    frontmatter={{
        title: entry.data.name.full,
        description: entry.data.description,
        tableOfContents: false,
    }}
>
    <div class="ref">
        <div class="ref__body">
            <Content />
        </div>
        <Infobox title={def.infoboxTitle} rows={rows} />
    </div>
</StarlightPage>

<style>
    .ref {
        display: grid;
        gap: 2rem;
        grid-template-columns: 1fr;
        align-items: start;
    }
    @media (min-width: 60rem) {
        .ref {
            grid-template-columns: 1fr 18rem;
        }
    }
</style>
