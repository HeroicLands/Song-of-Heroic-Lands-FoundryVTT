# Local environment configuration for SoHL development.
# Copy this file to .env.local and update the paths for your machine.
#
# Paths point to Foundry VTT data roots. The build scripts automatically
# append "Data/systems/sohl/" when deploying.
#
# Use absolute paths only. Shell variables ($HOME, ~) are NOT expanded.
#
# A *_DATA value may be a local path or a remote SFTP target. Local paths are
# deployed with an intrinsic file copy; remote targets are deployed over SFTP.
#
# Local path example:
#   FOUNDRYVTT_QA_DATA=/Users/yourname/Games/fvtt/data-dev
#
# Remote SFTP target example ([user@]host:/path):
#   FOUNDRYVTT_DEV_DATA=yourhost:/srv/docker/data/foundryvtt-dev
#   FOUNDRYVTT_DEV_DATA=deploy@yourhost:/srv/docker/data/foundryvtt-dev
#
# SFTP authentication for remote targets (all optional, per stage DEV/QA/PROD).
# Deploys use a pure-JS SSH client (no `ssh` binary required). By default the
# running SSH agent is used, so if ssh already works without asking for a
# passphrase, no extra config is needed.
#
# LINUX/UNIX/Mac
# Supports the standard SSH Agent, which stores SSH keys securely. Detected
# by the presence of the $SSH_AUTH_SOCK environment variable set by ssh-agent.
#
# WINDOWS
# Supports both the OpenSSH named pipe (\\.\pipe\openssh-ssh-agent) and/or
# the putty `pageant` protocols.
#   FOUNDRYVTT_DEV_AGENT=pageant         # (optional) Per-phase agent override
#   SOHL_SFTP_AGENT=pageant              # PuTTY Pageant, or a custom pipe/socket.
#                                        # Set once to apply to all phases
#
#   FOUNDRYVTT_DEV_USER=deploy           # overrides the user@ prefix / $USER
#   FOUNDRYVTT_DEV_PORT=22               # or set SOHL_SFTP_PORT for all stages
#   FOUNDRYVTT_DEV_KEY=/path/to/id_ed25519   # key-file PATH; skips the agent
#                                            # entirely (works with no agent at all)

# Path to the Foundry VTT application install for each environment.
FOUNDRYVTT_DEV=
FOUNDRYVTT_QA=
FOUNDRYVTT_PROD=

# Path to the Foundry VTT user data root for each environment.
# Used by "npm run push:dev", "npm run push:qa", "npm run push:prod".
FOUNDRYVTT_DEV_DATA=
FOUNDRYVTT_QA_DATA=
FOUNDRYVTT_PROD_DATA=

# Isolated data root for end-to-end (Cypress) tests. Point this at a FRESH,
# EMPTY directory — the E2E harness seeds a disposable world here and the test
# container serves it, so it never touches your dev/qa worlds. Local path only.
#   FOUNDRYVTT_TEST_DATA=/Users/yourname/Games/fvtt/data-e2e

# Container (Docker) settings — used by "npm run container:dev|qa|prod <cmd>".
# The container serves the *_DATA root above (bind-mounted at /data), so a
# "npm run push:<stage>" lands the system where the container will load it. The
# *_DATA value must be a LOCAL path here — remote SFTP targets can't be mounted.
# All settings below are optional.
#
#   FOUNDRYVTT_CONTAINER_IMAGE=felddy/foundryvtt:14   # image to run (this is the default)
#
# Host port to publish per stage (defaults: dev 30000, qa 30001, prod 30002 —
# distinct so stages can run at once). A stage is either local (containerized,
# so this is its published HTTP port) or a remote SFTP target (where *_PORT is
# the SSH port used by push:<stage>) — never both, so the name doesn't clash.
#   FOUNDRYVTT_DEV_PORT=30000
#   FOUNDRYVTT_QA_PORT=30001
#   FOUNDRYVTT_PROD_PORT=30002
#
# Foundry licensing/provisioning: every FOUNDRY_* and CONTAINER_* variable is
# passed straight through to the container. Provide ONE provisioning method
# (these are SECRETS — they stay in the gitignored .env.local). The download is
# cached (see below), so credentials are only needed on the first run.
# See https://hub.docker.com/r/felddy/foundryvtt for the full variable list.
#   FOUNDRY_USERNAME=your-foundry-account
#   FOUNDRY_PASSWORD=your-foundry-password
#   FOUNDRY_LICENSE_KEY=XXXX-XXXX-XXXX-XXXX-XXXX-XXXX
#   # ...or a timed download URL instead of username/password:
#   FOUNDRY_RELEASE_URL=https://...
#
# Auto-launch a specific world (its directory name under Data/worlds/). felddy
# regenerates Config/options.json from the env on each start, so set this rather
# than hand-editing options.json (which gets overwritten). Applies on container
# CREATE — run "npm run container:<stage> recreate" after changing it.
#   FOUNDRY_WORLD=my-world-dir-name
#
# Download cache (avoid re-downloading the Foundry zip). CONTAINER_CACHE is a
# path INSIDE the container; felddy's default is /data/container_cache, which —
# because the *_DATA root is mounted at /data — is <data>/container_cache/ on
# your host. So either:
#   a) drop foundryvtt-<version>.zip into <data>/container_cache/ (no config), OR
#   b) keep the zip in a SEPARATE host directory and set FOUNDRYVTT_CACHE to it —
#      the script bind-mounts that dir and sets CONTAINER_CACHE for you. Do NOT
#      set a raw CONTAINER_CACHE to a host path; it names a container path.
#   FOUNDRYVTT_CACHE=/Users/yourname/Downloads/foundry-cache

# End-to-end (Cypress) test harness — "npm run test:e2e" / "test:e2e:open".
# The "test" stage container (port 30003 by default) needs Foundry licensed like
# any instance. A license SIGNED for one installation does NOT transfer to
# another, and Foundry is single-seat per license — so the clean setup is to
# DEDICATE a spare license to the test stage (then dev + test can run at once):
#   FOUNDRYVTT_TEST_DATA=/Users/yourname/Games/fvtt/data-e2e   # separate EMPTY dir
#   FOUNDRYVTT_TEST_LICENSE_KEY=XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX  # a DIFFERENT key than dev
#   FOUNDRY_USERNAME=your-foundry-account   # account-wide; lets felddy SIGN the key
#   FOUNDRY_PASSWORD=your-foundry-password  # (a bare key stays unsigned: "requires signature")
# FOUNDRYVTT_TEST_DATA must be a separate, EMPTY dir — otherwise felddy finds an
# existing Config/license.json and ignores the key. Alternatively, sign once in a
# browser at http://localhost:30003/setup; the signed Config/license.json then
# persists (the seed wipes only the world, not Config). With a dedicated key,
# there is no license churn with dev. If you instead SHARE dev's license, stop
# the dev container first (single-seat) — the harness warns when another
# sohl-foundry-* is running.
# The seeded world + GM (all optional; defaults shown) — Cypress logs in with these:
#   SOHL_E2E_WORLD_ID=sohl-e2e
#   SOHL_E2E_WORLD_TITLE=SoHL E2E
#   SOHL_E2E_GM_NAME=Gamemaster
#   SOHL_E2E_GM_PASSWORD=sohl-e2e
#   FOUNDRYVTT_TEST_PORT=30003

# GitHub access for the legacy local release helper (utils/release.mjs) uses
# `gh auth login` — the gh CLI stores the token in your OS keychain and the
# script reads it via `gh auth token`. No token belongs in this file. (If a
# GITHUB_TOKEN is already exported in your environment, e.g. in CI, the script
# honors it — but don't add one here.)
