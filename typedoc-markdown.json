{
    "entryPoints": [
        "build/docbundle"
    ],
    "entryPointStrategy": "expand",
    "navigation": {
        "includeFolders": true,
        "includeGroups": false,
        "includeCategories": false
    },
    "tsconfig": "./tsconfig.docs.json",
    "out": "build/docs",
    "plugin": [
        "typedoc-plugin-markdown",
        "./utils/typedoc-plugin-datafield-schema.mjs"
    ],
    "theme": "markdown",
    "excludeExternals": true,
    "excludePrivate": true,
    "excludeInternal": true,
    "includeVersion": true,
    "readme": "docs/api-home.md",
    "projectDocuments": [
        "docs/concepts/architecture.md",
        "docs/concepts/lifecycle-model.md",
        "docs/concepts/assembly-architecture.md",
        "docs/how-to/getting-started.md",
        "docs/how-to/extension-points.md",
        "docs/how-to/lifecycle-hooks.md",
        "docs/how-to/actions.md",
        "docs/how-to/house-rules-cookbook.md",
        "docs/how-to/testing.md",
        "docs/reference/type-catalog.md",
        "docs/reference/modifier-model.md",
        "docs/reference/combat-resolution-pipeline.md",
        "docs/reference/body-structure.md",
        "docs/reference/effects-integration.md",
        "docs/reference/runtime-contracts.md",
        "docs/reference/scene-token-combatant.md",
        "docs/reference/calendar.md",
        "docs/reference/event-queue.md",
        "docs/contributing/api-docs-hosting.md",
        "docs/contributing/api-documentation-plan.md"
    ],
    "name": "Song of Heroic Lands API",
    "exclude": [],
    "skipErrorChecking": true,
    "excludeProtected": true
}
