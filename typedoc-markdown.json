{
    "entryPoints": ["src/index.ts"],
    "entryPointStrategy": "resolve",
    "navigation": {
        "includeFolders": false,
        "includeGroups": false,
        "includeCategories": false
    },
    "tsconfig": "./tsconfig.docs.json",
    "out": "build/docs",
    "plugin": [
        "typedoc-plugin-markdown",
        "./utils/typedoc-plugin-datafield-schema.mjs",
        "./utils/typedoc-plugin-foundry-links.mjs",
        "./utils/typedoc-plugin-root-namespace.mjs"
    ],
    "theme": "markdown",
    "excludeExternals": true,
    "excludePrivate": true,
    "excludeInternal": true,
    "includeVersion": true,
    "readme": "docs/api-home.md",
    "projectDocuments": ["docs/documentation.md"],
    "name": "Song of Heroic Lands API",
    "exclude": [],
    "skipErrorChecking": true,
    "excludeProtected": true,
    "treatWarningsAsErrors": true,
    "suppressCommentWarningsInDeclarationFiles": true,
    "highlightLanguages": [
        "bash",
        "css",
        "handlebars",
        "hbs",
        "html",
        "javascript",
        "js",
        "json",
        "jsonc",
        "markdown",
        "scss",
        "text",
        "ts",
        "typescript"
    ],
    "validation": {
        "notExported": false
    }
}
