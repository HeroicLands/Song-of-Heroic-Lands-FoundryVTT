{
    "entryPoints": ["build/docbundle"],
    "entryPointStrategy": "expand",
    "navigation": {
        "includeFolders": false,
        "includeGroups": false,
        "includeCategories": true
    },
    "categoryOrder": [
        "Core",
        "Documents/Actor",
        "Documents/Item",
        "Documents/Chat",
        "Documents/Combat",
        "Documents/Combatant",
        "Documents/Effect",
        "Documents/Scene",
        "Documents/Token",
        "Domain/General",
        "Domain/SkillBase",
        "Domain/Action",
        "Domain/Body",
        "Domain/Modifier",
        "Domain/Movement",
        "Domain/Result",
        "Domain/StrikeMode",
        "Applications",
        "Utility/Helpers",
        "Utility/AI",
        "Utility/Collection",
        "Utility/Constants",
        "*"
    ],
    "tsconfig": "./tsconfig.docs.json",
    "out": "build/docs",
    "plugin": [
        "typedoc-plugin-markdown",
        "./utils/typedoc-plugin-datafield-schema.mjs",
        "./utils/typedoc-plugin-source-category.mjs",
        "./utils/typedoc-plugin-foundry-links.mjs",
        "./utils/typedoc-plugin-nested-nav.mjs"
    ],
    "theme": "markdown",
    "excludeExternals": true,
    "excludePrivate": true,
    "excludeInternal": true,
    "includeVersion": true,
    "readme": "docs/api-home.md",
    "projectDocuments": ["docs/documentation.md"],
    "name": "Song of Heroic Lands API",
    "exclude": [],
    "skipErrorChecking": true,
    "excludeProtected": true,
    "treatWarningsAsErrors": true,
    "suppressCommentWarningsInDeclarationFiles": true,
    "highlightLanguages": [
        "bash",
        "css",
        "handlebars",
        "hbs",
        "html",
        "javascript",
        "js",
        "json",
        "jsonc",
        "markdown",
        "scss",
        "text",
        "ts",
        "typescript"
    ],
    "validation": {
        "notExported": false
    }
}
