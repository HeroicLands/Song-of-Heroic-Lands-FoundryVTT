{
    "name": "sohl",
    "productName": "Song of Heroic Lands",
    "description": "A Foundry VTT system for Song of Heroic Lands",
    "version": "0.7.0",
    "private": true,
    "author": {
        "name": "Tom Rodriguez",
        "email": "toasty@heroiclands.org",
        "url": "https://www.heroiclands.org"
    },
    "x-contact": {
        "discord": "toasty#8538",
        "bluesky": "@toasty.heroiclands.org"
    },
    "homepage": "https://www.heroicland.org",
    "license": "GPL-3.0-or-later AND CC-BY-SA-4.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/HeroicLands/Song-of-Heroic-Lands-FoundryVTT"
    },
    "bugs": "https://github.com/HeroicLands/Song-of-Heroic-Lands-FoundryVTT/issues",
    "engines": {
        "node": ">=24.0.0"
    },
    "type": "module",
    "browser": "./sohl.js",
    "exports": {
        "import": "./sohl.js"
    },
    "scripts": {
        "clean": "node utils/clean.mjs",
        "distclean": "node utils/clean.mjs --distclean",
        "build": "npm ci && npm run build:noci",
        "build:local": "npm i && npm run build:noci",
        "build:noci": "run-s lint build:types build:prepare test:coverage test:purity build:code",
        "build:prepare": "run-p build:css build:db build:system",
        "build:db": "run-s build:assets build:compiledb",
        "build:types": "tsc -p tsconfig.json",
        "build:system": "node ./utils/build-system-json.mjs",
        "build:css": "sass --load-path=scss scss/sohl.scss build/stage/css/sohl.css",
        "build:code": "vite build --mode release",
        "build:assets": "node utils/copy-assets.mjs",
        "build:icons": "node utils/build-icon-font.mjs",
        "build:compiledb": "node ./utils/packs/build-compendiums.mjs package compile",
        "build:unpackdb": "node ./utils/packs/build-compendiums.mjs package unpack",
        "packs:export": "node ./utils/packs/export.mjs",
        "packs:clean": "node ./utils/packs/clean-sources.mjs",
        "packs:rebuild": "run-s packs:export build:compiledb",
        "build:pack-release": "node utils/pack-release.mjs",
        "push:dev": "node utils/push-stage.mjs dev",
        "push:qa": "node utils/push-stage.mjs qa",
        "push:prod": "node utils/push-stage.mjs prod",
        "push:test": "node utils/push-stage.mjs test",
        "push:local-dev": "npm run push:qa",
        "container:dev": "node utils/foundry-container.mjs dev",
        "container:qa": "node utils/foundry-container.mjs qa",
        "container:prod": "node utils/foundry-container.mjs prod",
        "container:test": "node utils/foundry-container.mjs test",
        "deploy:local": "npm run deploy:qa",
        "deploy:qa": "run-s build push:qa",
        "deploy:dev": "run-s build push:dev",
        "deploy:prod": "run-s build push:prod",
        "deploy:release": "run-s build build:pack-release",
        "docs": "run-s docs:prepare docs:html docs:md docs:version",
        "docs:prepare": "run-s docs:catalog docs:bundle",
        "docs:catalog": "node utils/build-type-catalog.mjs",
        "docs:bundle": "node utils/build-docs-entry.mjs",
        "docs:html": "typedoc --options typedoc-html.json",
        "docs:md": "typedoc --options typedoc-markdown.json",
        "docs:version": "node utils/sync-doc-version.mjs",
        "docs:coverage": "run-s docs:prepare docs:coverage:check",
        "docs:coverage:check": "node utils/docs-coverage.mjs",
        "docs:serve": "http-server build/stage/docs -o -c-1",
        "predocs:watch": "run-s docs:prepare docs:html",
        "docs:watch": "run-p \"docs:html -- --watch\" docs:serve",
        "codeanddocs": "run-p build:code docs:html",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage --passWithNoTests",
        "test:purity": "vitest run -c vitest.purity.config.ts",
        "test:e2e:seed": "node utils/seed-test-world.mjs",
        "test:e2e:run": "node utils/e2e-run.mjs run",
        "test:e2e:openrun": "node utils/e2e-run.mjs open",
        "test:e2e": "run-s push:test test:e2e:seed test:e2e:run",
        "test:e2e:open": "run-s push:test test:e2e:seed test:e2e:openrun",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "run-s lint:todos lint:docs-index lint:labels lint:eslint lint:dts",
        "lint:eslint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "lint:todos": "node utils/check-todos.mjs",
        "lint:docs-index": "node utils/check-docs-index.mjs",
        "lint:labels": "node utils/check-labels.mjs",
        "lint:dts": "node utils/check-dts.mjs",
        "changeset": "changeset",
        "changeset:version": "changeset version",
        "changeset:check": "changeset check"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.26.9",
        "@changesets/cli": "^2.28.1",
        "@foundryvtt/foundryvtt-cli": "^1.0.4",
        "@octokit/rest": "^21.1.1",
        "@rollup/plugin-terser": "^0.4.4",
        "@types/file-saver": "^2.0.7",
        "@types/json-schema": "^7.0.15",
        "@typescript-eslint/eslint-plugin": "^8.28.0",
        "@typescript-eslint/parser": "^8.28.0",
        "@vitejs/plugin-react": "^4.4.1",
        "@vitest/coverage-v8": "^3.1.2",
        "@vitest/ui": "^3.1.2",
        "archiver": "^7.0.1",
        "cypress": "^15.18.0",
        "dotenv": "^16.4.7",
        "eslint": "^9.23.0",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-jsdoc": "^50.6.9",
        "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
        "glob": "^11.0.1",
        "handlebars": "^4.7.8",
        "http-server": "^14.1.1",
        "ix": "^7.0.0",
        "loglevel": "^1.9.2",
        "loglevel-plugin-prefix": "^0.8.4",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.1",
        "sass": "^1.69.0",
        "ssh2-sftp-client": "^12.1.1",
        "svg2ttf": "^6.1.0",
        "svgicons2svgfont": "^16.0.0",
        "svgo": "^4.0.1",
        "ttf2woff2": "^8.0.1",
        "typedoc": "0.27.6",
        "typedoc-github-theme": "0.2.1",
        "typedoc-plugin-markdown": "4.3.3",
        "typescript": "^5.3.3",
        "unidecode": "^1.1.0",
        "vite": "^6.2.3",
        "vite-plugin-banner": "^0.8.0",
        "vitest": "^3.1.2",
        "yaml": "^2.8.1"
    },
    "dependencies": {
        "jsep": "^1.4.0"
    }
}
